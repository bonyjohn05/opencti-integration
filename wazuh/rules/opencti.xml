<group name="opencti,threat_intel,">
  <rule id="100700" level="3">
     <if_sid>86600</if_sid>
    <field name="integration">opencti</field>
    <description>OpenCTI event received</description>
    <options>no_full_log</options>
  </rule>

  <rule id="100701" level="12">
    <if_sid>100700</if_sid>
    <field name="opencti.matched">true</field>
    <description>OpenCTI malicious IOC match: $(ioc.value)</description>
    <group>threat_intel,opencti_match,</group>
  </rule>

  <rule id="100702" level="5">
    <if_sid>100700</if_sid>
    <field name="opencti.error">.+</field>
    <description>OpenCTI lookup error: $(opencti.error)</description>
    <group>opencti_error,</group>
  </rule>
</group>